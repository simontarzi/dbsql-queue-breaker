{
  "datasets": [
    {
      "name": "warehouses",
      "displayName": "warehouses",
      "queryLines": [
        "WITH agg AS (\n  SELECT compute.warehouse_id AS warehouse_id,\n    COUNT(*) AS total_queries,\n    SUM(CASE WHEN waiting_at_capacity_duration_ms > 1000 THEN 1 ELSE 0 END) AS queued_queries,\n    ROUND(100.0*SUM(CASE WHEN waiting_at_capacity_duration_ms>1000 THEN 1 ELSE 0 END)/COUNT(*),1) AS pct_queued,\n    ROUND(AVG(CASE WHEN waiting_at_capacity_duration_ms>1000 THEN waiting_at_capacity_duration_ms END)/1000.0,1) AS avg_queue_s,\n    ROUND(approx_percentile(CASE WHEN waiting_at_capacity_duration_ms>1000 THEN waiting_at_capacity_duration_ms END,0.95)/1000.0,1) AS p95_queue_s,\n    ROUND(MAX(waiting_at_capacity_duration_ms)/1000.0,1) AS max_queue_s,\n    COUNT(DISTINCT CASE WHEN waiting_at_capacity_duration_ms>1000 THEN date(start_time) END) AS queue_days\n  FROM system.query.history\n  WHERE compute.type='WAREHOUSE' AND compute.warehouse_id IS NOT NULL\n    AND start_time >= current_date() - INTERVAL 30 DAYS\n  GROUP BY compute.warehouse_id\n  HAVING queued_queries > 0\n),\nq AS (\n  SELECT compute.warehouse_id AS wid, start_time AS a,\n    timestampadd(MILLISECOND, CAST(waiting_at_capacity_duration_ms AS INT), start_time) AS b\n  FROM system.query.history\n  WHERE compute.type='WAREHOUSE' AND waiting_at_capacity_duration_ms > 1000\n    AND start_time >= current_date() - INTERVAL 30 DAYS\n),\nev AS (SELECT wid, a AS ts, 1 AS d FROM q UNION ALL SELECT wid, b AS ts, -1 AS d FROM q),\nrun AS (SELECT wid, ts, SUM(d) OVER (PARTITION BY wid ORDER BY ts, d DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS depth FROM ev),\ndep AS (SELECT wid, MAX(depth) AS peak_depth, CAST(ROUND(approx_percentile(depth,0.95)) AS INT) AS p95_depth FROM run GROUP BY wid)\nSELECT a.warehouse_id, a.total_queries, a.queued_queries, a.pct_queued,\n  a.avg_queue_s, a.p95_queue_s, a.max_queue_s, ROUND(a.max_queue_s/60.0,1) AS max_queue_min, a.queue_days,\n  COALESCE(d.peak_depth,0) AS peak_depth, COALESCE(d.p95_depth,0) AS p95_depth,\n  CAST(CEIL(COALESCE(d.p95_depth,0)/10.0) AS INT) AS clusters_to_add,\n  CASE WHEN a.p95_queue_s<10 THEN '1. <10s' WHEN a.p95_queue_s<30 THEN '2. 10-30s'\n       WHEN a.p95_queue_s<60 THEN '3. 30-60s' WHEN a.p95_queue_s<300 THEN '4. 1-5min'\n       ELSE '5. 5min+' END AS wait_bucket\nFROM agg a LEFT JOIN dep d ON d.wid = a.warehouse_id"
      ]
    },
    {
      "name": "daily",
      "displayName": "daily",
      "queryLines": [
        "SELECT date(start_time) AS day,\n  SUM(CASE WHEN waiting_at_capacity_duration_ms>1000 THEN 1 ELSE 0 END) AS queued_queries,\n  ROUND(AVG(CASE WHEN waiting_at_capacity_duration_ms>1000 THEN waiting_at_capacity_duration_ms END)/1000.0,1) AS avg_queue_s\nFROM system.query.history\nWHERE compute.type='WAREHOUSE' AND start_time >= current_date() - INTERVAL 30 DAYS\nGROUP BY date(start_time) ORDER BY day"
      ]
    }
  ],
